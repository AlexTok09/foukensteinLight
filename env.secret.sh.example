#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Foukenstein deployment_v1 — template des SECRETS
#
# Copie ce fichier en `env.secret.sh` (non versionné) et remplis les valeurs.
# Ne JAMAIS committer env.secret.sh.
# ─────────────────────────────────────────────────────────────────────────────

# Clé API Mistral (utilisée par generate_light.py)
export MISTRAL_API_KEY=""

# Clé API Runpod (utilisée par runpod_tts_client.py)
export RUNPOD_API_KEY=""

# ── Runpod Network Volume — S3 API (pour scripts/sync_xtts_to_volume.sh) ─────
# Crée ces credentials dans la console Runpod :
#   Settings → Storage → S3 API Keys → Create New Key
# Elles donnent accès à *tes* network volumes via une API S3-compatible.
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# Optionnel — les défauts dans sync_xtts_to_volume.sh visent déjà eu-ro-1 :
#export S3_BUCKET="srvvzpk6jj"
#export S3_ENDPOINT_URL="https://s3api-eu-ro-1.runpod.io"
#export AWS_DEFAULT_REGION="eu-ro-1"
#export S3_PREFIX="xtts"
